// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Driver {
  id                  Int        @id @default(autoincrement())
  firstName           String
  lastName            String
  program             String?
  licenseNumber       String     @unique
  licenseState        String?
  licenseExpiration   DateTime?
  driverStatus        String?
  suspensionStartDate DateTime?
  suspensionEndDate   DateTime?
  licenseStatus       String?
  createdBy           Int?
  vehicles            Vehicle[]
  accidents           Accident[]
  tickets             Ticket[]
  documents           Document[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
}

model Vehicle {
  id                 Int        @id @default(autoincrement())
  programVehicle     String?
  year               String?
  make               String?
  model              String?
  vinNumber          String?    @unique
  licensePlateNumber String?
  gpsTracker         String?
  imeiNumber         String?
  serialNumber       String?
  existingDamages    String?
  createdBy          Int?
  driverId           Int?
  driver             Driver?    @relation(fields: [driverId], references: [id])
  accidents          Accident[]
  tickets            Ticket[]
  documents          Document[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model Accident {
  id                       Int       @id @default(autoincrement())
  driverLicenseNumber      String?
  driverFirstName          String?
  driverLastName           String?
  programPartnerName       String?
  accidentDate             DateTime?
  vinNumber                String?
  year                     String?
  make                     String?
  model                    String?
  licensePlate             String?
  dcNumber                 String?
  policeReportDate         DateTime?
  policeReportTime         String?
  dateReportedToInsurance  DateTime?
  staffMemberReporting     String?
  claimNumber              String?
  adjusterAssigned         String?
  documentation            String?
  createdBy                Int?
  driverId                 Int?
  driver                   Driver?   @relation(fields: [driverId], references: [id])
  vehicleId                Int?
  vehicle                  Vehicle?  @relation(fields: [vehicleId], references: [id])
  documents                Document[]
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model Ticket {
  id                  Int       @id @default(autoincrement())
  driverLicenseNumber String?
  driverFirstName     String?
  driverLastName      String?
  programPartnerName  String?
  vinNumber           String?
  violationDate       DateTime?
  citationNumber      String?
  citationDate        DateTime?
  citationType        String?
  citationAmount      String?
  createdBy           Int?
  driverId            Int?
  driver              Driver?   @relation(fields: [driverId], references: [id])
  vehicleId           Int?
  vehicle             Vehicle?  @relation(fields: [vehicleId], references: [id])
  documents           Document[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model ServiceRequest {
  id               Int       @id @default(autoincrement())
  ticketId         String    @unique
  dateOfReport     DateTime?
  issueWith        String?
  requestType      String?
  other            String?
  incidentLocation String?
  details          String?
  attachments      String?
  createdBy        Int?
  documents        Document[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Document {
  id               Int             @id @default(autoincrement())
  fileName         String
  originalName     String
  fileUrl          String
  fileData         Bytes?
  fileType         String?
  fileSize         Int?
  driverId         Int?
  driver           Driver?         @relation(fields: [driverId], references: [id])
  vehicleId        Int?
  vehicle          Vehicle?        @relation(fields: [vehicleId], references: [id])
  accidentId       Int?
  accident         Accident?       @relation(fields: [accidentId], references: [id])
  ticketId         Int?
  ticket           Ticket?         @relation(fields: [ticketId], references: [id])
  serviceRequestId Int?
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])
  createdAt        DateTime        @default(now())
}

model HelpdeskTicket {
  id             Int       @id @default(autoincrement())
  token          String    @unique @default(cuid())
  category       String?
  priority       String?
  name           String
  email          String
  subject        String
  message        String
  role           String?
  submittedAt    DateTime  @default(now())
  acknowledgedAt DateTime?
  escalatedAt    DateTime?
}
